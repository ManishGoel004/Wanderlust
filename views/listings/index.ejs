<% layout("/layouts/boilerplate") %>
<style>
    #filters {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
    }

    .filter {
        flex: 0 0 auto;
        margin-top: 1rem;
        text-align: center;
        margin-right: 2rem;
        opacity: 0.7;
        transition: all 0.2s ease;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
        margin-bottom: 0;
    }

    .filter-link {
        text-decoration: none;
        color: inherit;
    }   

    .tax-info {
        display: none;
    }

    .tax-toggle {
        flex: 0 0 auto;
        border: 1px solid black;
        border-radius: 1rem;
        height: 3rem;
        padding: 1rem;
        margin-left: 2rem;
        display: flex;
        align-items: center;
        font-size: 0.9rem;
        margin-top: 1rem;
    }

    .active-filter {
        opacity: 1 !important;
        border-bottom: 2px solid black;
        transform: scale(1.03);
    }

    @media (max-width: 992px) {

        .tax-toggle {
            display: none;
        }

        .filter {
            width: 95px;
            margin-right: 0.75rem;
            margin-left: 0.75rem;
            margin-top: 1.25rem;
        }

        .filter p {
            font-size: 0.75rem;
        }
    }

    @media (max-width: 768px) {

        .filter {
            width: 85px;
            margin-right: 0.5rem;
            margin-left: 0.5rem;
        }

        .filter p {
            font-size: 0.72rem;
        }
    }
</style>
<div id="filters">
    <a href="/listings?category=trending" class="filter-link">
        <div class="filter <%= category === 'trending' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>
    </a>
    <a href="/listings?category=rooms" class="filter-link">
        <div class="filter <%= category === 'rooms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </div>
    </a>
    <a href="/listings?category=iconic-cities" class="filter-link">
        <div class="filter <%= category === 'iconic-cities' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>
    </a>
    <a href="/listings?category=mountains" class="filter-link">
        <div class="filter <%= category === 'mountains' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </div>
    </a>
    <a href="/listings?category=castles" class="filter-link">
        <div class="filter <%= category === 'castles' ? 'active-filter' : '' %>">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </div>
    </a>
    <a href="/listings?category=amazing-pools" class="filter-link">
        <div class="filter <%= category === 'amazing-pools' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </div>
    </a>
    <a href="/listings?category=camping" class="filter-link">
        <div class="filter <%= category === 'camping' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </div>
    </a>
    <a href="/listings?category=farms" class="filter-link">
        <div class="filter <%= category === 'farms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </div>
    </a>
    <a href="/listings?category=arctic" class="filter-link">
        <div class="filter <%= category === 'arctic' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>
    </a>
    <a href="/listings?category=domes" class="filter-link">
        <div class="filter <%= category === 'domes' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-landmark-dome"></i></div>
            <p>Domes</p>
        </div>
    </a>
    <a href="/listings?category=boats" class="filter-link">
        <div class="filter <%= category === 'boats' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-ship"></i></div>
            <p>Boats</p>
        </div>
    </a>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
    </div>
</div>
<% if(searchError){ %>
    <div class="d-flex justify-content-center mt-3">
        <div class="alert alert-warning">
            <%= searchError %>
        </div>
    </div>
<% } %>
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 mt-3">
    <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card col listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %> image" style="height: 20rem">
                <div class="card-img-overlay"><%= listing.title %></div>
                <div class="card-body">
                    <p class="card-text"><b><%= listing.title %></b> <br>
                        &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
                        <i class="tax-info">&nbsp; +18% GST</i>
                    </p>
                </div>
            </div>
        </a>
    <% } %>
</div>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");

    if(taxSwitch) {
        const taxEnabled =
            localStorage.getItem("taxEnabled") === "true";

        taxSwitch.checked = taxEnabled;

        if(taxEnabled){
            let taxInfo = document.getElementsByClassName("tax-info");
            for(info of taxInfo){
                info.style.display = "inline";
            }
        }

        taxSwitch.addEventListener("change", () => {
            localStorage.setItem("taxEnabled", taxSwitch.checked);

            let taxInfo = document.getElementsByClassName("tax-info");

            for(info of taxInfo){
                if(taxSwitch.checked){
                    info.style.display = "inline";
                }
                else{
                    info.style.display = "none";
                }
            }
        });
    }

    const searchInput = document.querySelector(".search-inp");

    if(searchInput){
        searchInput.addEventListener("search", () => {
            if(searchInput.value === ""){
                const url = new URL(window.location);
                url.searchParams.delete("search");
                window.location.href = url.toString();
            }
        });
    }

    document.querySelectorAll(".filter-link").forEach(link => {
        link.addEventListener("click", function(e){
            e.preventDefault();

            const currentUrl = new URL(window.location);
            const currentCategory = currentUrl.searchParams.get("category");
            const clickedUrl = new URL(this.href);
            const clickedCategory = clickedUrl.searchParams.get("category");

            if(currentCategory === clickedCategory){
                currentUrl.searchParams.delete("category");
            } else {
                currentUrl.searchParams.set("category", clickedCategory);
            }

            window.location.href = currentUrl.toString();
        });

    });
</script>

